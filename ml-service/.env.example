# ML Service Environment Configuration

# Service Port
PORT=3009

# FinBERT Configuration
FINBERT_URL=http://localhost:5000
USE_FINBERT=true

# Optional: External ML Model URL (fallback)
# ML_MODEL_URL=https://your-ml-api.com/classify
# ML_MODEL_API_KEY=your_api_key_here

# Optional: LLM for Impact Scoring (fallback)
# ML_LLM_URL=https://your-llm-api.com/complete
# ML_LLM_API_KEY=your_llm_api_key_here

# For Docker deployment, use service name:
# FINBERT_URL=http://finbert-service:5000
