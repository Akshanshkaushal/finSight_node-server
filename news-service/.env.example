# News Service Environment Configuration

# Service Port
PORT=3005

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/finsight_news

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka Configuration
KAFKA_BROKERS=localhost:9092

# ML Service Configuration (for FinBERT classification)
ML_SERVICE_URL=http://localhost:3009
ML_SERVICE_TIMEOUT=10000
USE_ML_SERVICE=true

# News Fetch Interval (cron format)
NEWS_FETCH_INTERVAL=0 */6 * * *

# For Docker deployment, use service names:
# ML_SERVICE_URL=http://ml-service:3009
# REDIS_HOST=redis
# KAFKA_BROKERS=kafka:9092
